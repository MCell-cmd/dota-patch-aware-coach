# Copia este archivo a .env.local y rellena lo que necesites.

# IA (opcional): si está presente, /api/report redacta el reporte con Claude.
# Si no está, la app usa el reporte determinista y sigue funcionando igual.
ANTHROPIC_API_KEY=

# Modelo de Claude para la redacción del reporte (opcional).
# Por defecto: claude-opus-4-8
CLAUDE_MODEL=claude-opus-4-8

# OpenDota (opcional): sube el rate limit. La API pública funciona sin esto.
OPENDOTA_API_KEY=
