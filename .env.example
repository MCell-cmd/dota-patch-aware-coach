# Copia este archivo a .env.local y rellena lo que necesites.

# IA (opcional): si está presente, /api/report redacta el reporte con un modelo
# vía OpenRouter (https://openrouter.ai). Si no está, la app usa el reporte
# determinista y sigue funcionando igual.
OPENROUTER_API_KEY=

# Slug del modelo en OpenRouter (opcional). Por defecto un modelo barato con
# buen razonamiento. Ejemplos: anthropic/claude-sonnet-4.6 (más caro),
# deepseek/deepseek-v4-pro (más capaz), openai/gpt-5-mini.
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# OpenDota (opcional): sube el rate limit. La API pública funciona sin esto.
OPENDOTA_API_KEY=

# URL pública del sitio (para Open Graph / metadataBase). En prod ponla con
# tu dominio, p. ej. https://tu-dominio.com
NEXT_PUBLIC_SITE_URL=

# Analítica sin cookies (opcional): tu dominio en Plausible. Si está, se cargan
# el script y los eventos de conversión (reporte generado, copiado, login).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Login con Steam ---------------------------------------------------------
# Secreto para firmar la cookie de sesión (HMAC). OBLIGATORIO en producción:
# genera uno con `openssl rand -base64 32`. En local funciona con un default
# inseguro, no lo uses en prod.
AUTH_SECRET=

# Steam Web API key (opcional): solo para mostrar nombre y avatar del usuario.
# El login funciona sin ella (devuelve el Account ID). Obtenla en:
# https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
